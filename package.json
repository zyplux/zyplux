{
  "name": "zyplux",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*",
      "tests/*"
    ],
    "catalog": {
      "@eslint/js": "^10.0.1",
      "@optique/core": "^1.1.1",
      "@optique/run": "^1.1.1",
      "@types/bun": "^1.3.14",
      "@typescript-eslint/type-utils": "^8.63.0",
      "@typescript-eslint/utils": "^8.63.0",
      "@vitest/coverage-istanbul": "^4.1.10",
      "@vitest/eslint-plugin": "^1.6.21",
      "eslint": "^10.6.0",
      "eslint-config-prettier": "^10.1.8",
      "eslint-plugin-perfectionist": "^5.10.0",
      "eslint-plugin-prefer-arrow-functions": "^3.10.1",
      "eslint-plugin-react": "^7.37.5",
      "eslint-plugin-react-hooks": "^7.1.1",
      "eslint-plugin-unicorn": "^71.1.0",
      "knip": "^6.25.0",
      "npm-check-updates": "^22.2.9",
      "prettier": "^3.9.4",
      "typescript": "^6.0.3",
      "typescript-eslint": "^8.63.0",
      "vitest": "^4.1.10",
      "zod": "^4.4.3"
    }
  },
  "scripts": {
    "knip": "knip",
    "format": "prettier --write --cache --log-level warn .",
    "typecheck": "tsc -b",
    "lint": "eslint . --cache",
    "lint:fix": "bun run lint --fix",
    "test": "vitest run",
    "upgrade": "npm-check-updates --root --workspaces --format group",
    "cz": "bun apps/cz/src/index.ts"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "@zyplux/eslint-config": "workspace:*",
    "@zyplux/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "knip": "catalog:",
    "npm-check-updates": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
