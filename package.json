{
  "name": "zyp-cerberus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "packages/*",
      "tests/*"
    ],
    "catalog": {
      "@eslint/js": "^10.0.1",
      "@typescript-eslint/rule-tester": "^8.61.1",
      "@typescript-eslint/type-utils": "^8.61.1",
      "@typescript-eslint/utils": "^8.61.1",
      "@vitest/eslint-plugin": "^1.6.20",
      "bun-types": "^1.3.14",
      "eslint": "^10.5.0",
      "eslint-config-prettier": "^10.1.8",
      "eslint-plugin-perfectionist": "^5.9.1",
      "eslint-plugin-prefer-arrow-functions": "^3.9.1",
      "eslint-plugin-react": "^7.37.5",
      "eslint-plugin-react-hooks": "^7.1.1",
      "eslint-plugin-unicorn": "^67.0.0",
      "knip": "^6.17.1",
      "npm-check-updates": "^22.2.3",
      "prettier": "^3.8.4",
      "typescript": "^6.0.3",
      "typescript-eslint": "^8.61.1",
      "vitest": "^4.1.9",
      "zod": "^4.4.3"
    }
  },
  "scripts": {
    "knip": "knip",
    "format": "prettier --write --cache --log-level warn .",
    "typecheck": "tsc -p . && bun --elide-lines=0 --filter '*' typecheck",
    "lint": "eslint . --cache",
    "lint:fix": "bun run lint --fix",
    "test": "vitest run",
    "upgrade": "npm-check-updates --root --workspaces --format group",
    "release": "bun scripts/release.ts",
    "push": "bun scripts/pusher.ts",
    "clone": "bun scripts/clone-reference.ts"
  },
  "devDependencies": {
    "@zyplux/eslint-config": "workspace:*",
    "bun-types": "catalog:",
    "eslint": "catalog:",
    "knip": "catalog:",
    "npm-check-updates": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
