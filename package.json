{
  "name": "zyp-cerberus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "packages/*",
      "tests/*"
    ],
    "catalog": {
      "@eslint/js": "^10.0.1",
      "@typescript-eslint/rule-tester": "^8.60.0",
      "@typescript-eslint/utils": "^8.60.0",
      "bun-types": "^1.3.14",
      "eslint": "^10.4.1",
      "eslint-config-prettier": "^10.1.8",
      "eslint-plugin-perfectionist": "^5.9.0",
      "eslint-plugin-prefer-arrow-functions": "^3.9.1",
      "eslint-plugin-react": "^7.37.5",
      "eslint-plugin-react-hooks": "^7.1.1",
      "eslint-plugin-unicorn": "^64.0.0",
      "knip": "^6.15.0",
      "lefthook": "^2.1.9",
      "npm-check-updates": "^22.2.1",
      "prettier": "^3.8.3",
      "typescript": "^6.0.3",
      "typescript-eslint": "^8.60.0",
      "vitest": "^4.1.7",
      "zod": "^4.4.3"
    }
  },
  "scripts": {
    "prepare": "lefthook install",
    "knip": "knip",
    "format": "prettier --write .",
    "typecheck": "tsc -p . && bun --filter '*' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "bun --filter '*' test",
    "upgrade": "npm-check-updates --root --workspaces --format group",
    "release": "bun scripts/release.ts",
    "push": "bun scripts/pusher.ts"
  },
  "devDependencies": {
    "@zyplux/eslint-config": "workspace:*",
    "bun-types": "catalog:",
    "eslint": "catalog:",
    "knip": "catalog:",
    "lefthook": "catalog:",
    "npm-check-updates": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  }
}
