{
  "name": "@zyplux/eslint-config",
  "version": "0.6.7",
  "description": "Shared ESLint flat config and custom rules",
  "keywords": [
    "eslint",
    "eslintconfig",
    "eslint-config",
    "flat-config",
    "typescript"
  ],
  "license": "MIT",
  "author": "Sergiy Yeskov <sergiy.yeskov@gmail.com>",
  "homepage": "https://github.com/zyplux/zyplux",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zyplux/zyplux.git",
    "directory": "packages/eslint-config"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#scripts/print-config": "./scripts/print-config.ts",
    "#create-rule": "./src/create-rule.ts",
    "#plugin": "./src/plugin.ts",
    "#package.json": "./package.json",
    "#configs/base": "./src/configs/base.ts",
    "#configs/typescript": "./src/configs/typescript.ts"
  },
  "files": [
    "README.md",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dump-rules": "bun run scripts/dump-rules.ts"
  },
  "dependencies": {
    "@eslint/js": "catalog:",
    "@typescript-eslint/type-utils": "catalog:",
    "@typescript-eslint/utils": "catalog:",
    "@vitest/eslint-plugin": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-perfectionist": "catalog:",
    "eslint-plugin-prefer-arrow-functions": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-unicorn": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "peerDependencies": {
    "eslint": "catalog:",
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@zyplux/tsconfig": "workspace:*",
    "@zyplux/util": "workspace:*",
    "typescript": "catalog:",
    "zod": "catalog:"
  }
}
