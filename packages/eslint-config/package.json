{
  "name": "@totvibe/eslint-config",
  "version": "0.1.1",
  "description": "Shared ESLint flat config and custom rules for totvibe projects",
  "keywords": [
    "eslint",
    "eslintconfig",
    "eslint-config",
    "flat-config",
    "typescript"
  ],
  "license": "MIT",
  "author": "Sergiy Yeskov <sergiy.yeskov@gmail.com>",
  "homepage": "https://github.com/realSergiy/totvibe-eslint",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/realSergiy/totvibe-eslint.git",
    "directory": "packages/eslint-config"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@eslint/js": "catalog:",
    "@typescript-eslint/utils": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-perfectionist": "catalog:",
    "eslint-plugin-prefer-arrow-functions": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-unicorn": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "peerDependencies": {
    "eslint": "catalog:",
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@typescript-eslint/rule-tester": "catalog:",
    "bun-types": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
