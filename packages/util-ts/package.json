{
  "name": "@zyplux/util",
  "version": "0.5.1",
  "description": "Small Bun utilities: assertions, polling, bounded-concurrency mapping, zod-validated JSON reads, repo-URL normalization, package.json/pyproject manifest schemas, and a git/gh shell harness",
  "keywords": [
    "bun",
    "utilities",
    "zod",
    "json",
    "shell",
    "concurrency",
    "manifest"
  ],
  "license": "MIT",
  "author": "Sergiy Yeskov <sergiy.yeskov@gmail.com>",
  "homepage": "https://github.com/zyplux/zyplux",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zyplux/zyplux.git",
    "directory": "packages/util-ts"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./contracts": {
      "types": "./src/contracts.ts",
      "default": "./src/contracts.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "README.md",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@zyplux/tsconfig": "workspace:*",
    "zod": "catalog:"
  }
}
